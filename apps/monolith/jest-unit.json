{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testRegex": "\\.spec\\.ts$",
  "transform": {
    "^.+\\.ts$": ["ts-jest", {
      "tsconfig": "../../tsconfig.base.json"
    }]
  },
  "testTimeout": 10000,
  "moduleNameMapper": {
    "^@nettapu/shared(.*)$": "<rootDir>/../../packages/shared/src$1"
  },
  "testEnvironment": "node"
}
